# Dome Configuration Example
# Copy this file to .env and update with your actual values

# Required: OpenAI API Key for AI features
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Path to your notes vault (default: ~/dome)
DOME_VAULT_PATH=$HOME/dome-notes

# Optional: PostgreSQL connection string
# For local development, you can use Docker:
# docker run --name dome-postgres -e POSTGRES_DB=dome -e POSTGRES_USER=dome -e POSTGRES_PASSWORD=dome123 -p 5433:5432 -d pgvector/pgvector:pg15
POSTGRES_URI=postgresql://dome:dome123@localhost:5433/dome

# Optional: Vector index name (default: notes_vectors)
DOME_INDEX_NAME=notes_vectors
