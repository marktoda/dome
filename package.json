{
  "name": "@dome/sdk",
  "version": "0.3.1",
  "description": "Dome — markdown-vault SDK with a four-concept engine model (Vault, Proposal, Processor, Effect).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/",
    "contracts/agent-stream.ts",
    "contracts/capture.ts",
    "contracts/product-readiness.ts",
    "contracts/source-document.ts",
    "assets/extensions/",
    "assets/model-providers/",
    "assets/source-handlers/",
    "bin/dome",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/server.ts",
      "default": "./src/mcp/server.ts"
    }
  },
  "bin": {
    "dome": "bin/dome"
  },
  "scripts": {
    "test": "bun test ./tests",
    "build:pwa": "bun run --cwd pwa build",
    "check:pwa": "bun run --cwd pwa check",
    "build:home-artifact": "bun scripts/home-artifact.ts",
    "build:home-distribution": "bun scripts/home-macos-distribution.ts",
    "test:invariants": "bun test tests/invariants",
    "typecheck": "bunx tsc --noEmit && bunx tsc --noEmit -p tsconfig.bundles.json && bunx tsc --noEmit -p tsconfig.scripts.json",
    "v1:smoke": "bun scripts/v1-smoke.ts",
    "v1:llm-smoke": "bun scripts/v1-llm-smoke.ts",
    "v1:dogfood-snapshot": "bun scripts/v1-dogfood-snapshot.ts",
    "v1:dogfood-report": "bun scripts/v1-dogfood-report.ts",
    "v1:dogfood-preflight": "bun scripts/v1-dogfood-preflight.ts",
    "eval": "bun scripts/eval.ts",
    "eval:product": "bun scripts/product-quality.ts",
    "release:package-rehearsal": "bun scripts/release-package.ts",
    "v1:implementation-check": "bun run v1:check && bun run release:package-rehearsal",
    "v1:check": "bun run typecheck && bun run check:pwa && git diff --check && bun test ./tests && bun run v1:smoke",
    "v1:release-check": "bun scripts/v1-release-check.ts",
    "product:journey": "bun test tests/harness/scenarios/cli-surface/capture-ingest-captured-block.scenario.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.206",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.27.0",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "string-width": "^7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "playwright-core": "1.61.1",
    "typescript": "^5.5.0"
  }
}
