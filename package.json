{
  "name": "@dome/sdk",
  "version": "0.1.0",
  "description": "Dome — markdown-vault SDK with a four-concept engine model (Vault, Proposal, Processor, Effect).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    }
  },
  "bin": {
    "dome": "bin/dome"
  },
  "scripts": {
    "test": "bun test",
    "test:invariants": "bun test tests/invariants",
    "typecheck": "bunx tsc --noEmit && bunx tsc --noEmit -p tsconfig.bundles.json && bunx tsc --noEmit -p tsconfig.scripts.json",
    "v1:smoke": "bun scripts/v1-smoke.ts",
    "v1:llm-smoke": "bun scripts/v1-llm-smoke.ts",
    "v1:dogfood-snapshot": "bun scripts/v1-dogfood-snapshot.ts",
    "v1:dogfood-report": "bun scripts/v1-dogfood-report.ts",
    "v1:dogfood-preflight": "bun scripts/v1-dogfood-preflight.ts",
    "v1:check": "bun run typecheck && git diff --check && bun test && bun run v1:smoke",
    "v1:release-check": "bun scripts/v1-release-check.ts"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.27.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
